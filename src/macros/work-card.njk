{% macro render(project, index) %}
    <article class="work-card">
        {% if project.link %}
            <a class="work-card__link" href="{{ project.link }}" target="_blank" rel="noopener noreferrer" aria-label="Ver projeto {{ project.title }}"></a>
        {% endif %}
        <div class="work-card__media">
            {% if project.image %}
                <img
                    class="work-card__img"
                    src="/assets/media/{{ project.image }}"
                    alt="{{ project.title }}"
                    loading="lazy"
                >
                <div class="work-card__overlay" aria-hidden="true"></div>
            {% else %}
                <span class="work-card__index">{{ index }}</span>
            {% endif %}
        </div>
        <div class="work-card__body">
            <div class="work-card__header">
                <h3 class="work-card__title">
                    {% if project.link %}
                        <a href="{{ project.link }}" target="_blank" rel="noopener noreferrer">{{ project.title }}</a>
                    {% else %}
                        {{ project.title }}
                    {% endif %}
                </h3>
                {% if project.year %}
                    <span class="work-card__year">{{ project.year }}</span>
                {% endif %}
            </div>
            {% if project.category %}
                <span class="work-card__category">{{ project.category }}</span>
            {% endif %}
            {% if project.description %}
                <p class="work-card__description">{{ project.description }}</p>
            {% endif %}
            {% if project.tags %}
                <ul class="work-card__tags list-unstyled">
                    {% for tag in project.tags %}
                        <li class="work-card__tag">{{ tag }}</li>
                    {% endfor %}
                </ul>
            {% endif %}
        </div>
    </article>
{% endmacro %}
